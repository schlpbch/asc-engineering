---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '@mcp-orchestrator/design-system/components/Container.astro';
import Card from '@mcp-orchestrator/design-system/components/Card.astro';
---

<BaseLayout title="Impressum — asc.engineering" description="Legal notice and publishing information for asc.engineering.">
  <section id="impressum" class="py-16">
    <Container maxWidth="4xl" size="sm">
      <h2 class="text-xl font-semibold mb-8 text-slate-900 dark:text-white">Impressum</h2>
      <Card variant="default" size="md">
        <div class="prose prose-invert max-w-none">
          <h3 class="text-lg font-semibold text-slate-900 dark:text-white mb-4">Website Information</h3>
          <p class="text-sm text-slate-600 dark:text-slate-400 mb-6 leading-relaxed">
            <strong>Publisher:</strong><br />
            Dr. Andreas Schlapbach<br />
            Muri bei Bern, Switzerland<br />
            <br />
            <strong>Email:</strong> <a href="mailto:schlpbch@gmail.com" class="text-accent-700 dark:text-accent-400 hover:text-accent-600">schlpbch@gmail.com</a>
          </p>

          <h3 class="text-lg font-semibold text-slate-900 dark:text-white mb-4">Liability for Content</h3>
          <p class="text-sm text-slate-600 dark:text-slate-400 mb-6 leading-relaxed">
            The contents of this website have been created with care. However, I cannot guarantee the accuracy, completeness, or timeliness of the content. As the website publisher, I am liable for my own content according to § 7 I TMG (Telemediengesetz) and general laws. However, I am not obligated to monitor transmitted or stored third-party information or to investigate circumstances that indicate illegal activity.
          </p>

          <h3 class="text-lg font-semibold text-slate-900 dark:text-white mb-4">Liability for Links</h3>
          <p class="text-sm text-slate-600 dark:text-slate-400 mb-6 leading-relaxed">
            My website contains links to external websites. I have no influence over the design and contents of these external pages and therefore cannot accept liability for them. The respective provider is responsible for the content of linked pages. At the time of linking, the linked pages contained no illegal content. However, I have no continuing control over the content of linked pages. Should you discover illegal content, I ask you to notify me immediately by email.
          </p>

          <h3 class="text-lg font-semibold text-slate-900 dark:text-white mb-4">Copyright</h3>
          <p class="text-sm text-slate-600 dark:text-slate-400 mb-6 leading-relaxed">
            The layout and design of this website, including all graphics, texts, and other elements, are protected by copyright and intellectual property law. Use is permitted only for personal information purposes. Any reproduction, distribution, or public transmission of the content in whole or in part without my express written consent is prohibited.
          </p>

          <h3 class="text-lg font-semibold text-slate-900 dark:text-white mb-4">Dispute Resolution</h3>
          <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">
            The European Commission provides a platform for online dispute resolution (OS): <a href="https://ec.europa.eu/consumers/odr" target="_blank" rel="noopener" class="text-accent-700 dark:text-accent-400 hover:text-accent-600">https://ec.europa.eu/consumers/odr</a>. However, I am not obligated to participate in dispute resolution proceedings.
          </p>
        </div>
      </Card>
    </Container>
  </section>
</BaseLayout>
