---
import BaseLayout from '../layouts/BaseLayout.astro';
import ExperienceSection from '../components/ExperienceSection.astro';
import SkillsSection from '../components/SkillsSection.astro';
import ProjectsSection from '../components/ProjectsSection.astro';
import { experience, skills, projects } from '../data/work';
---

<BaseLayout
  title="Work — asc.engineering"
  description="Experience, skills, and projects spanning AI/ML, enterprise architecture, and distributed systems at scale."
>
  <ExperienceSection experience={experience} />
  <SkillsSection skills={skills} />
  <ProjectsSection projects={projects} />
</BaseLayout>
