---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '@mcp-orchestrator/design-system/components/Container.astro';
import Card from '@mcp-orchestrator/design-system/components/Card.astro';
import Badge from '@mcp-orchestrator/design-system/components/Badge.astro';
import Stack from '@mcp-orchestrator/design-system/components/Stack.astro';
import { publications } from '../data/publications';
---

<BaseLayout
  title="Academia — asc.engineering"
  description="Academic publications spanning software composition, handwriting recognition, machine learning, and LLM agentic systems."
>
  <!-- Publications -->
  <section
    id="publications"
    class="py-16 border-b border-slate-100 dark:border-slate-800"
  >
    <Container maxWidth="4xl" size="sm">
      <h2 class="text-xl font-semibold mb-8 text-slate-900 dark:text-white">
        Publications
      </h2>
      <Stack direction="vertical" size="md">
        <!-- In Review -->
        <Card variant="default" size="md">
          <Stack
            direction="horizontal"
            align="center"
            size="sm"
            className="mb-4"
          >
            <h3 class="font-semibold text-slate-900 dark:text-white">
              In Review
            </h3>
            <Badge intent="warning" variant="default" size="sm" shape="pill"
              >Under Review</Badge
            >
          </Stack>
          <Stack direction="vertical" size="sm">
            {
              publications.inReview.map((p) => (
                <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed flex gap-2">
                  <span class="text-accent-700 dark:text-accent-400 mt-0.5 shrink-0">
                    ›
                  </span>
                  <span>
                    {p.text}
                    {p.href && (
                      <a
                        href={p.href}
                        target="_blank"
                        rel="noopener"
                        class="ml-1.5 inline-flex items-center gap-0.5 text-accent-700 dark:text-accent-400 hover:text-accent-600 dark:hover:text-accent-300 text-xs font-medium transition-colors"
                      >
                        <svg
                          class="w-3 h-3"
                          fill="currentColor"
                          viewBox="0 0 24 24"
                          aria-hidden="true"
                        >
                          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6zm-1 1.5L18.5 9H13V3.5zM8 17v-1h8v1H8zm0-3v-1h8v1H8zm0-3V10h4v1H8z" />
                        </svg>
                        arXiv
                      </a>
                    )}
                  </span>
                </p>
              ))
            }
          </Stack>
        </Card>

        <!-- Books, Chapters & Journals -->
        <Card variant="default" size="md">
          <Stack
            direction="horizontal"
            align="center"
            size="sm"
            className="mb-4"
          >
            <h3 class="font-semibold text-slate-900 dark:text-white">
              Books, Chapters &amp; Journals
            </h3>
            <Badge intent="success" variant="default" size="sm" shape="pill"
              >{publications.booksAndJournals.length} publications</Badge
            >
          </Stack>
          <Stack direction="vertical" size="sm">
            {
              publications.booksAndJournals.map((p) => (
                <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed flex gap-2">
                  <span class="text-accent-700 dark:text-accent-400 mt-0.5 shrink-0">
                    ›
                  </span>
                  <span>
                    {p.text}
                    {p.href && (
                      <a
                        href={p.href}
                        target="_blank"
                        rel="noopener"
                        class="ml-1.5 inline-flex items-center gap-0.5 text-accent-700 dark:text-accent-400 hover:text-accent-600 dark:hover:text-accent-300 text-xs font-medium transition-colors"
                      >
                        <svg
                          class="w-3 h-3"
                          fill="currentColor"
                          viewBox="0 0 24 24"
                          aria-hidden="true"
                        >
                          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6zm-1 1.5L18.5 9H13V3.5zM8 17v-1h8v1H8zm0-3v-1h8v1H8zm0-3V10h4v1H8z" />
                        </svg>
                        PDF
                      </a>
                    )}
                  </span>
                </p>
              ))
            }
          </Stack>
        </Card>

        <!-- Conference Papers -->
        <Card variant="default" size="md">
          <Stack
            direction="horizontal"
            align="center"
            size="sm"
            className="mb-4"
          >
            <h3 class="font-semibold text-slate-900 dark:text-white">
              Conference Papers
            </h3>
            <Badge intent="info" variant="default" size="sm" shape="pill"
              >{publications.conferencesPapers.length} papers</Badge
            >
          </Stack>
          <Stack direction="vertical" size="sm">
            {
              publications.conferencesPapers.map((p) => (
                <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed flex gap-2">
                  <span class="text-accent-700 dark:text-accent-400 mt-0.5 shrink-0">
                    ›
                  </span>
                  <span>
                    {p.text}
                    {p.href && (
                      <a
                        href={p.href}
                        target="_blank"
                        rel="noopener"
                        class="ml-1.5 inline-flex items-center gap-0.5 text-accent-700 dark:text-accent-400 hover:text-accent-600 dark:hover:text-accent-300 text-xs font-medium transition-colors"
                      >
                        <svg
                          class="w-3 h-3"
                          fill="currentColor"
                          viewBox="0 0 24 24"
                          aria-hidden="true"
                        >
                          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6zm-1 1.5L18.5 9H13V3.5zM8 17v-1h8v1H8zm0-3v-1h8v1H8zm0-3V10h4v1H8z" />
                        </svg>
                        PDF
                      </a>
                    )}
                  </span>
                </p>
              ))
            }
          </Stack>
        </Card>

        <!-- Presentations -->
        <Card variant="default" size="md">
          <Stack
            direction="horizontal"
            align="center"
            size="sm"
            className="mb-4"
          >
            <h3 class="font-semibold text-slate-900 dark:text-white">
              Presentations
            </h3>
            <Badge intent="info" variant="default" size="sm" shape="pill"
              >{publications.presentations.length} presentations</Badge
            >
          </Stack>
          <Stack direction="vertical" size="sm">
            {
              publications.presentations.map((p) => (
                <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed flex gap-2">
                  <span class="text-accent-700 dark:text-accent-400 mt-0.5 shrink-0">
                    ›
                  </span>
                  <span>
                    {p.text}
                    {p.href && (
                      <a
                        href={p.href}
                        target="_blank"
                        rel="noopener"
                        class="ml-1.5 inline-flex items-center gap-0.5 text-accent-700 dark:text-accent-400 hover:text-accent-600 dark:hover:text-accent-300 text-xs font-medium transition-colors"
                      >
                        <svg
                          class="w-3 h-3"
                          fill="currentColor"
                          viewBox="0 0 24 24"
                          aria-hidden="true"
                        >
                          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6zm-1 1.5L18.5 9H13V3.5zM8 17v-1h8v1H8zm0-3v-1h8v1H8zm0-3V10h4v1H8z" />
                        </svg>
                        PDF
                      </a>
                    )}
                  </span>
                </p>
              ))
            }
          </Stack>
        </Card>

        <!-- Theses -->
        <Card variant="default" size="md">
          <Stack
            direction="horizontal"
            align="center"
            size="sm"
            className="mb-4"
          >
            <h3 class="font-semibold text-slate-900 dark:text-white">Theses</h3>
            <Badge intent="secondary" variant="default" size="sm" shape="pill"
              >{publications.theses.length} theses</Badge
            >
          </Stack>
          <Stack direction="vertical" size="sm">
            {
              publications.theses.map((p) => (
                <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed flex gap-2">
                  <span class="text-accent-700 dark:text-accent-400 mt-0.5 shrink-0">
                    ›
                  </span>
                  <span>
                    {p.text}
                    {p.href && (
                      <a
                        href={p.href}
                        target="_blank"
                        rel="noopener"
                        class="ml-1.5 inline-flex items-center gap-0.5 text-accent-700 dark:text-accent-400 hover:text-accent-600 dark:hover:text-accent-300 text-xs font-medium transition-colors"
                      >
                        <svg
                          class="w-3 h-3"
                          fill="currentColor"
                          viewBox="0 0 24 24"
                          aria-hidden="true"
                        >
                          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6zm-1 1.5L18.5 9H13V3.5zM8 17v-1h8v1H8zm0-3v-1h8v1H8zm0-3V10h4v1H8z" />
                        </svg>
                        PDF
                      </a>
                    )}
                  </span>
                </p>
              ))
            }
          </Stack>
        </Card>
      </Stack>
    </Container>
  </section>
</BaseLayout>
