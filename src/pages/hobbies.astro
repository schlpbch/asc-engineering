---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '@mcp-orchestrator/design-system/components/Container.astro';
import Card from '@mcp-orchestrator/design-system/components/Card.astro';
---

<BaseLayout title="Hobbies — asc.engineering" description="Interests and hobbies outside of work.">
  <!-- Hobbies placeholder -->
  <section id="hobbies" class="py-16">
    <Container maxWidth="4xl" size="sm">
      <h2 class="text-xl font-semibold mb-8 text-slate-900 dark:text-white">Hobbies & Interests</h2>
      <Card variant="default" size="md">
        <p class="text-slate-600 dark:text-slate-400 leading-relaxed">
          Coming soon. This section is under construction.
        </p>
      </Card>
    </Container>
  </section>
</BaseLayout>
