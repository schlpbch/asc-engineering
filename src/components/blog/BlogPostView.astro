---
import Container from '@asc-engineering/design-system/components/Container.astro';
import Breadcrumb from '@asc-engineering/design-system/components/Breadcrumb.astro';
import Badge from '@asc-engineering/design-system/components/Badge.astro';
import Stack from '@asc-engineering/design-system/components/Stack.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const formattedDate = post.data.date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const readingTime = Math.ceil(post.body.split(/\s+/).length / 200);
---

<section class="py-16">
  <Container maxWidth="4xl" size="sm">
    <Breadcrumb
      items={[
        { label: 'Home', href: '/' },
        { label: 'Blog', href: '/blog' },
        { label: post.data.title },
      ]}
      separator="slash"
    />

    <div class="mt-8">
      <h1
        class="text-3xl font-bold tracking-tight text-slate-900 dark:text-white mb-4"
      >
        {post.data.title}
      </h1>

      <Stack
        direction="horizontal"
        align="center"
        size="sm"
        className="flex-wrap mb-6"
      >
        <span class="text-sm text-slate-600 dark:text-slate-400"
          >{formattedDate}</span
        >
        <span class="text-sm text-slate-600 dark:text-slate-400"
          >{readingTime} min read</span
        >
        {
          post.data.tags.length > 0 && (
            <>
              <span class="text-slate-400 dark:text-slate-600">·</span>
              <Stack direction="horizontal" size="xs" wrap>
                {post.data.tags.map((tag: string) => (
                  <Badge
                    intent="secondary"
                    variant="outline"
                    size="sm"
                    shape="rounded"
                  >
                    {tag}
                  </Badge>
                ))}
              </Stack>
            </>
          )
        }
      </Stack>

      <div
        class="prose prose-slate dark:prose-invert prose-sm sm:prose-base lg:prose-lg max-w-none
          prose-headings:font-semibold prose-headings:mt-8 prose-headings:mb-4
          prose-h2:text-2xl prose-h3:text-xl
          prose-p:text-slate-700 dark:prose-p:text-slate-400 prose-p:leading-relaxed
          prose-a:text-accent-700 dark:prose-a:text-accent-400 hover:prose-a:text-accent-600 dark:hover:prose-a:text-accent-300
          prose-code:text-accent-700 dark:prose-code:text-accent-300 prose-code:bg-slate-100 dark:prose-code:bg-slate-800 prose-code:rounded prose-code:px-1.5 prose-code:py-0.5
          prose-pre:bg-slate-100 dark:prose-pre:bg-slate-800 prose-pre:border prose-pre:border-slate-200 dark:prose-pre:border-slate-700
          prose-ul:text-slate-700 dark:prose-ul:text-slate-400
          prose-strong:text-slate-900 dark:prose-strong:text-white"
      >
        <slot />
      </div>

      <div class="mt-12 pt-8 border-t border-slate-200 dark:border-slate-800">
        <a
          href="/blog"
          class="inline-flex items-center gap-2 text-accent-700 dark:text-accent-400 hover:text-accent-600 dark:hover:text-accent-300 transition-colors"
        >
          ← Back to Blog
        </a>
      </div>
    </div>
  </Container>
</section>
