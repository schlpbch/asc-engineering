---
import Card from '@asc-engineering/design-system/components/Card.astro';
import Badge from '@asc-engineering/design-system/components/Badge.astro';
import Stack from '@asc-engineering/design-system/components/Stack.astro';
import PageSection from '../layout/PageSection.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  posts: CollectionEntry<'blog'>[];
}

const { posts } = Astro.props;

// Calculate reading time
const getReadingTime = (content: string): number => {
  const wordCount = content.split(/\s+/).length;
  return Math.ceil(wordCount / 200);
};

// Extract all unique tags
const allTags = Array.from(
  new Set(posts.flatMap((post) => post.data.tags || []))
).sort();
---

<PageSection id="blog" title="Latest Articles">
  {/* Tag filter buttons */}
  {allTags.length > 0 && (
    <div class="flex flex-wrap gap-2 mb-8 pb-6 border-b border-slate-200 dark:border-slate-800">
      <button
        data-filter="all"
        class="tag-filter-btn px-3 py-1.5 rounded-lg text-sm font-medium bg-accent-100 dark:bg-accent-900/30 text-accent-700 dark:text-accent-400 transition-colors active"
      >
        All
      </button>
      {allTags.map((tag) => (
        <button
          data-filter={tag}
          class="tag-filter-btn px-3 py-1.5 rounded-lg text-sm font-medium bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400 hover:bg-slate-200 dark:hover:bg-slate-700 transition-colors"
        >
          {tag}
        </button>
      ))}
    </div>
  )}

  {/* Blog post list */}
  <Stack direction="vertical" size="md">
    {posts.map((post) => {
      const readingTime = getReadingTime(post.body);
      const postTags = post.data.tags?.join(',') || '';

      return (
        <a
          href={`/blog/${post.id}`}
          class="blog-post group block no-underline"
          data-tags={postTags}
        >
          <Card variant="default" size="md" interactive className="h-full">
            <Stack direction="vertical" size="sm" className="h-full">
              <Stack
                direction="horizontal"
                align="center"
                size="sm"
                justify="between"
                className="flex-col sm:flex-row"
              >
                <h3 class="font-semibold text-slate-900 dark:text-white group-hover:text-accent-600 dark:group-hover:text-accent-400 transition-colors flex-1">
                  {post.data.title}
                </h3>
                <div class="flex items-center gap-3 shrink-0 mt-2 sm:mt-0">
                  <span class="text-xs text-slate-500 dark:text-slate-500">
                    {post.data.date.toLocaleDateString('en-US', {
                      year: 'numeric',
                      month: 'long',
                      day: 'numeric',
                    })}
                  </span>
                  <span class="text-xs text-slate-500 dark:text-slate-500">
                    {readingTime} min read
                  </span>
                </div>
              </Stack>
              <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed flex-1">
                {post.data.description}
              </p>
              {post.data.tags && post.data.tags.length > 0 && (
                <Stack direction="horizontal" size="xs" wrap>
                  {post.data.tags.map((tag) => (
                    <Badge
                      intent="secondary"
                      variant="outline"
                      size="sm"
                      shape="rounded"
                    >
                      {tag}
                    </Badge>
                  ))}
                </Stack>
              )}
            </Stack>
          </Card>
        </a>
      );
    })}
  </Stack>
</PageSection>

<script>
  if (document.querySelector('.tag-filter-btn')) {
    const filterBtns = document.querySelectorAll('.tag-filter-btn');
    const posts = document.querySelectorAll('.blog-post');

    filterBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const filter = btn.dataset.filter;

        // Update active button
        filterBtns.forEach((b) => {
          b.classList.remove(
            'bg-accent-100',
            'dark:bg-accent-900/30',
            'text-accent-700',
            'dark:text-accent-400'
          );
          b.classList.add(
            'bg-slate-100',
            'dark:bg-slate-800',
            'text-slate-600',
            'dark:text-slate-400'
          );
        });
        btn.classList.remove(
          'bg-slate-100',
          'dark:bg-slate-800',
          'text-slate-600',
          'dark:text-slate-400'
        );
        btn.classList.add(
          'bg-accent-100',
          'dark:bg-accent-900/30',
          'text-accent-700',
          'dark:text-accent-400'
        );

        // Show/hide posts
        posts.forEach((post) => {
          if (filter === 'all') {
            post.classList.remove('hidden');
          } else {
            const postTags = post.dataset.tags?.split(',') || [];
            if (postTags.includes(filter)) {
              post.classList.remove('hidden');
            } else {
              post.classList.add('hidden');
            }
          }
        });
      });
    });
  }
</script>
