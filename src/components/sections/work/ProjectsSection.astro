---
import Card from '@asc-engineering/design-system/components/Card.astro';
import Badge from '@asc-engineering/design-system/components/Badge.astro';
import Stack from '@asc-engineering/design-system/components/Stack.astro';
import PageSection from '../../layout/PageSection.astro';
import type { Project } from '../../../data/work';
import { techUrls } from '../../../data/work';

interface Props {
  projects: Project[];
}

const { projects } = Astro.props;
---

<PageSection title="Projects" subtitle="Key technical initiatives and contributions.">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    {
      projects.map((project) => (
        <Card variant="interactive" size="md">
          <a
            href={project.href}
            target="_blank"
            rel="noopener noreferrer"
            class="block group"
          >
            <h3 class="font-semibold text-slate-900 dark:text-white group-hover:text-accent-700 dark:group-hover:text-accent-400 transition-colors">
              {project.name}
            </h3>
            <p class="mt-2 text-sm text-slate-600 dark:text-slate-400 leading-relaxed">
              {project.description}
            </p>
            <div class="mt-3 flex flex-wrap gap-1.5">
              {project.tech.map((tag) => {
                const url = techUrls[tag];
                return url ? (
                  <a
                    href={url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-block hover:opacity-80 transition-opacity"
                    onclick="event.stopPropagation();"
                  >
                    <Badge intent="secondary" variant="outline" size="sm">
                      {tag}
                    </Badge>
                  </a>
                ) : (
                  <Badge intent="secondary" variant="outline" size="sm">
                    {tag}
                  </Badge>
                );
              })}
            </div>
          </a>
        </Card>
      ))
    }
  </div>
</PageSection>
