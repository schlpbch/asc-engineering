---
import Card from '@asc-engineering/design-system/components/Card.astro';
import Badge from '@asc-engineering/design-system/components/Badge.astro';
import Stack from '@asc-engineering/design-system/components/Stack.astro';
import PageSection from '../../layout/PageSection.astro';
import type { Role } from '../../../data/work';

interface Props {
  experience: Role[];
}

const { experience } = Astro.props;
const isCurrent = (period: string) => period.includes('Present');
---

<PageSection id="experience" title="Experience" border>
  <div class="relative pl-8 space-y-8">
    {/* Timeline rail */}
    <div class="absolute left-[6px] top-0 bottom-0 w-0.5 bg-gradient-to-b from-accent-500 via-accent-500 to-slate-200 dark:to-slate-700" />

    {experience.map((role, idx) => (
      <div class="relative">
        {/* Timeline dot */}
        <div
          class:list={[
            'absolute -left-[18px] top-1 w-3 h-3 rounded-full border-4 border-white dark:border-slate-900',
            isCurrent(role.period)
              ? 'bg-accent-500 animate-pulse'
              : 'bg-accent-500',
          ]}
        />

        <Card variant="default" size="md">
          <Stack
            direction="horizontal"
            align="start"
            justify="between"
            className="flex-col sm:flex-row mb-3"
          >
            <div>
              <h3 class="font-semibold text-slate-900 dark:text-white">
                {role.title}
              </h3>
              <p class="text-sm text-accent-700 dark:text-accent-400">
                {role.company} · {role.location}
              </p>
            </div>
            <Badge intent="secondary" variant="outline" size="sm" shape="pill">
              {role.period}
            </Badge>
          </Stack>
          <Stack direction="vertical" size="xs">
            {role.bullets.map((b) => (
              <p class="text-sm text-slate-600 dark:text-slate-400 flex gap-2">
                <span class="text-accent-500 mt-0.5 shrink-0">›</span>
                <Fragment set:html={b} />
              </p>
            ))}
          </Stack>
        </Card>
      </div>
    ))}
  </div>
</PageSection>
