---
import Card from '@asc-engineering/design-system/components/Card.astro';
import Input from '@asc-engineering/design-system/components/Input.astro';
import Textarea from '@asc-engineering/design-system/components/Textarea.astro';
import Button from '@asc-engineering/design-system/components/Button.astro';
import Alert from '@asc-engineering/design-system/components/Alert.astro';
import PageSection from '../layout/PageSection.astro';
---

<PageSection title="Get in Touch">
  <Card variant="default" size="md">
    <p class="text-slate-600 dark:text-slate-400 mb-6 leading-relaxed">
      I'm interested in conversations about AI systems, distributed
      architecture, spec-driven development, and the future of agentic
      ecosystems. Feel free to reach out with questions or collaboration ideas.
    </p>

    <div id="form-status"></div>

    <form
      name="contact"
      method="POST"
      data-netlify="true"
      netlify-honeypot="bot-field"
      class="space-y-4"
    >
      <input type="hidden" name="form-name" value="contact" />
      <div class="hidden"><input name="bot-field" /></div>

      <div class="space-y-2">
        <label
          for="name"
          class="block text-sm font-medium text-slate-900 dark:text-white"
        >
          Name <span class="text-red-500">*</span>
        </label>
        <Input
          id="name"
          type="text"
          name="name"
          placeholder="Your name"
          required
        />
      </div>

      <div class="space-y-2">
        <label
          for="email"
          class="block text-sm font-medium text-slate-900 dark:text-white"
        >
          Email <span class="text-red-500">*</span>
        </label>
        <Input
          id="email"
          type="email"
          name="email"
          placeholder="your@email.com"
          required
        />
      </div>

      <div class="space-y-2">
        <label
          for="subject"
          class="block text-sm font-medium text-slate-900 dark:text-white"
        >
          Subject <span class="text-red-500">*</span>
        </label>
        <Input
          id="subject"
          type="text"
          name="subject"
          placeholder="What is this about?"
          required
        />
      </div>

      <div class="space-y-2">
        <label
          for="message"
          class="block text-sm font-medium text-slate-900 dark:text-white"
        >
          Message <span class="text-red-500">*</span>
        </label>
        <Textarea
          id="message"
          name="message"
          placeholder="Your message..."
          rows={6}
          required
        />
      </div>

      <Button type="submit" intent="primary" fullWidth>Send Message</Button>
    </form>
  </Card>
</PageSection>

<script>
  const form = document.querySelector('form');
  const statusDiv = document.getElementById('form-status');

  if (form && statusDiv) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(form);

      const makeAlert = (ok: boolean, message: string) => {
        const div = document.createElement('div');
        const [bgClass, borderClass, textClass] = ok
          ? [
              'bg-green-50 dark:bg-green-950/30',
              'border-green-200 dark:border-green-800',
              'text-green-800 dark:text-green-300',
            ]
          : [
              'bg-red-50 dark:bg-red-950/30',
              'border-red-200 dark:border-red-800',
              'text-red-800 dark:text-red-300',
            ];
        div.className = `mb-6 p-4 border rounded-lg ${bgClass} ${borderClass}`;
        const p = document.createElement('p');
        p.className = `text-sm font-medium ${textClass}`;
        p.textContent = message;
        div.appendChild(p);
        return div;
      };

      try {
        const response = await fetch('/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: new URLSearchParams(formData as any).toString(),
        });

        statusDiv.innerHTML = '';
        if (response.ok) {
          statusDiv.appendChild(
            makeAlert(
              true,
              "✓ Message sent successfully! I'll get back to you soon.",
            ),
          );
          form.reset();
        } else {
          statusDiv.appendChild(
            makeAlert(
              false,
              'Something went wrong. Please try again or email directly.',
            ),
          );
        }
      } catch {
        statusDiv.appendChild(
          makeAlert(
            false,
            'Network error. Please check your connection and try again.',
          ),
        );
      }
    });
  }
</script>
