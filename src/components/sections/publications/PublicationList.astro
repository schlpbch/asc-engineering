---
import Stack from '@asc-engineering/design-system/components/Stack.astro';
import type { Publication } from '../../../data/publications';

interface Props {
  items: Publication[];
  linkLabel?: string;
}

const { items, linkLabel = 'PDF' } = Astro.props;
---

<Stack direction="vertical" size="sm">
  {
    items.map((p) => (
      <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed flex gap-2">
        <span class="text-accent-700 dark:text-accent-400 mt-0.5 shrink-0">
          ›
        </span>
        <span>
          {p.text}
          {p.href && (
            <a
              href={p.href}
              target="_blank"
              rel="noopener noreferrer"
              class="ml-1.5 inline-flex items-center gap-0.5 text-accent-700 dark:text-accent-400 hover:text-accent-600 dark:hover:text-accent-300 text-xs font-medium transition-colors"
            >
              <svg
                class="w-3 h-3"
                fill="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6zm-1 1.5L18.5 9H13V3.5zM8 17v-1h8v1H8zm0-3v-1h8v1H8zm0-3V10h4v1H8z" />
              </svg>
              {linkLabel}
            </a>
          )}
        </span>
      </p>
    ))
  }
</Stack>
