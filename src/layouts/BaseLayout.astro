---
import Header from '@asc-engineering/design-system/components/Header.astro';
import Footer from '@asc-engineering/design-system/components/Footer.astro';
import Stack from '@asc-engineering/design-system/components/Stack.astro';
import IconButton from '@asc-engineering/design-system/components/IconButton.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
}

const {
  title = 'asc.engineering',
  description = 'Andreas Schlapbach — AI/ML Initiative Lead & Enterprise Architect at SBB. PhD in Pattern Recognition and Machine Learning (summa cum laude) from the University of Berne. Active contributor to the open-source ecosystem, e.g. contributor to MCP working groups (transport wg, governance wg, and others).',
  ogImage = '/og-default.svg',
  ogType = 'website',
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta property="og:url" content={canonicalUrl} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />

    <title>{title}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      />
    </noscript>

    <script is:inline>
      (function () {
        const stored = localStorage.getItem('theme');
        const prefersDark = window.matchMedia(
          '(prefers-color-scheme: dark)',
        ).matches;
        if (stored === 'dark' || (!stored && prefersDark)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>

  <body
    class="bg-white dark:bg-slate-950 text-slate-900 dark:text-slate-100 transition-colors duration-200 min-h-screen"
  >
    <Header sticky maxWidth="4xl">
      <Fragment slot="nav">
        <a
          href="/"
          class="px-3 py-1.5 rounded-md text-sm text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
          >Home</a
        >
        <a
          href="/about"
          class="px-3 py-1.5 rounded-md text-sm text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
          >About</a
        >
        <a
          href="/work"
          class="px-3 py-1.5 rounded-md text-sm text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
          >Work</a
        >
        <a
          href="/publications"
          class="px-3 py-1.5 rounded-md text-sm text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
          >Publications</a
        >
        <a
          href="/opensource"
          class="px-3 py-1.5 rounded-md text-sm text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
          >Open Source</a
        >
        <a
          href="/hobbies"
          class="px-3 py-1.5 rounded-md text-sm text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
          >Hobbies</a
        >
        <a
          href="/contact"
          class="px-3 py-1.5 rounded-md text-sm text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
          >Contact</a
        >
      </Fragment>

      <Fragment slot="actions">
        <IconButton
          id="theme-toggle"
          ariaLabel="Toggle dark mode"
          title="Toggle dark mode"
        >
          <svg
            class="w-4 h-4 hidden dark:block"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M17.657 17.657l-.707-.707M6.343 6.343l-.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z"
            ></path>
          </svg>
          <svg
            class="w-4 h-4 block dark:hidden"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"
            ></path>
          </svg>
        </IconButton>
      </Fragment>

      <Fragment slot="mobile-menu">
        <Stack direction="vertical" size="xs">
          <a
            href="/"
            class="block px-3 py-2 rounded-md text-sm hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
            >Home</a
          >
          <a
            href="/about"
            class="block px-3 py-2 rounded-md text-sm hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
            >About</a
          >
          <a
            href="/work"
            class="block px-3 py-2 rounded-md text-sm hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
            >Work</a
          >
          <a
            href="/publications"
            class="block px-3 py-2 rounded-md text-sm hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
            >Publications</a
          >
          <a
            href="/opensource"
            class="block px-3 py-2 rounded-md text-sm hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
            >Open Source</a
          >
          <a
            href="/hobbies"
            class="block px-3 py-2 rounded-md text-sm hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
            >Hobbies</a
          >
          <a
            href="/contact"
            class="block px-3 py-2 rounded-md text-sm hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
            >Contact</a
          >
        </Stack>
      </Fragment>
    </Header>

    <main>
      <slot />
    </main>

    <Footer
      variant="minimal"
      maxWidth="4xl"
      copyright={`© ${new Date().getFullYear()} Andreas Schlapbach`}
    >
      <Fragment slot="bottom">
        <div class="flex flex-wrap items-center gap-4">
          <a
            href="https://astro.build"
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-1.5 hover:text-accent-600 dark:hover:text-accent-400 transition-colors"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 128 128"
              class="w-4 h-4"
              aria-hidden="true"
            >
              <g
                class="hover:text-accent-600 dark:hover:text-accent-400"
                fill="currentColor"
              >
                <path
                  d="M47.7 107.1c-5.5-5-7.2-15.7-4.9-23.4 4 4.9 9.6 6.4 15.4 7.3 8.9 1.3 17.6.8 25.9-3.2l2.8-1.7a18 18 0 0 1-7.2 20l-5.5 3.8c-5.6 3.8-7.2 8.2-5 14.7l.2.7a14 14 0 0 1-6.6-5.6 15.8 15.8 0 0 1-2.6-8.6c0-1.5 0-3-.2-4.5-.5-3.7-2.2-5.3-5.5-5.4-3.3-.1-5.9 2-6.6 5.2l-.2.7Z"
                ></path>
                <path
                  d="M16 82.4s16.5-8 33-8l12.4-38.3c.5-2 1.8-3.2 3.3-3.2 1.6 0 3 1.3 3.4 3.2l12.4 38.3c19.6 0 33 8 33 8l-28-76c-.8-2.3-2.2-3.7-4-3.7H48c-1.8 0-3.1 1.4-4 3.7l-28 76Z"
                ></path>
              </g>
              <path
                class="hover:text-accent-600 dark:hover:text-accent-400"
                fill="currentColor"
                d="M47.7 107.1c-5.5-5-7.2-15.7-4.9-23.4 4 4.9 9.6 6.4 15.4 7.3 8.9 1.3 17.6.8 25.9-3.2l2.8-1.7a18 18 0 0 1-7.2 20l-5.5 3.8c-5.6 3.8-7.2 8.2-5 14.7l.2.7a14 14 0 0 1-6.6-5.6 15.8 15.8 0 0 1-2.6-8.6c0-1.5 0-3-.2-4.5-.5-3.7-2.2-5.3-5.5-5.4-3.3-.1-5.9 2-6.6 5.2l-.2.7Z"
              ></path>
              <defs>
                <linearGradient
                  id="astro-gradient"
                  x1="64.7"
                  x2="77.4"
                  y1="119.2"
                  y2="77.4"
                  gradientUnits="userSpaceOnUse"
                >
                  <stop stop-color="#D83333"></stop>
                  <stop offset="1" stop-color="#F041FF"></stop>
                </linearGradient>
              </defs>
            </svg>
            Built in Switzerland with ❤️
          </a>
          <span class="text-slate-400 dark:text-slate-600">·</span>
          <a
            href="/impressum"
            class="hover:text-accent-600 dark:hover:text-accent-400 transition-colors"
            >Impressum</a
          >
          <span class="text-slate-400 dark:text-slate-600">·</span>
          <a
            href="/privacy"
            class="hover:text-accent-600 dark:hover:text-accent-400 transition-colors"
            >Privacy</a
          >
        </div>
      </Fragment>
    </Footer>

    <script>
      const btn = document.getElementById('theme-toggle');
      btn?.addEventListener('click', () => {
        const isDark = document.documentElement.classList.toggle('dark');
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
      });
    </script>
  </body>
</html>
